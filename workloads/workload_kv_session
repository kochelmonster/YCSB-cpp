# YCSB-cpp Application Workload: Session Store / Mutable User State
# Real-world pattern:
#   - Web session storage
#   - User state and preferences
#   - Per-user mutable activity records
#
# Read/update ratio: 50/50
# Request distribution: zipfian

recordcount=100000
operationcount=100000
workload=com.yahoo.ycsb.workloads.CoreWorkload

readallfields=true

readproportion=0.50
updateproportion=0.50
scanproportion=0
insertproportion=0
readmodifywriteproportion=0

requestdistribution=zipfian

# Batching and binary keys for maximum throughput
leaves.batch_size=64
lmdb.batch_size=64
leveldb.batch_size=64
rocksdb.batch_size=64
leaves.binary_key=true
lmdb.binary_key=true
leveldb.binary_key=true
rocksdb.binary_key=true

# YCSB-cpp Application Workload: Write-Heavy Event Ingest
# Real-world pattern:
#   - Event ingestion
#   - Log collection
#   - Stream capture with occasional rereads and corrections
#
# Read/update/insert ratio: 10/20/70
# Request distribution: uniform

recordcount=100000
operationcount=100000
workload=com.yahoo.ycsb.workloads.CoreWorkload

readallfields=true

readproportion=0.10
updateproportion=0.20
scanproportion=0
insertproportion=0.70
readmodifywriteproportion=0

requestdistribution=uniform
insertorder=hashed

# Default batching and binary keys for maximum throughput
leaves.batch_size=64
lmdb.batch_size=64
leveldb.batch_size=64
rocksdb.batch_size=64
leaves.binary_key=true
lmdb.binary_key=true
leveldb.binary_key=true
rocksdb.binary_key=true

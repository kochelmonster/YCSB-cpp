# YCSB-cpp Application Workload: Ordered Range Scan (10 Items)
# Real-world pattern:
#   - Pagination
#   - Short transaction history lookups
#   - Feed page retrieval
#
# Read/scan ratio: 50/50
# Scan length: fixed 10 items
# Request distribution: zipfian

recordcount=100000
operationcount=100000
workload=com.yahoo.ycsb.workloads.CoreWorkload

readallfields=true

readproportion=0.50
updateproportion=0
scanproportion=0.50
insertproportion=0
readmodifywriteproportion=0

requestdistribution=zipfian

minscanlength=10
maxscanlength=10
scanlengthdistribution=uniform
